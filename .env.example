# ============================================================
# Stack-Secrets fuer docker-compose.example.yml (Full-Stack)
# Diese Werte werden per ${...} in die Compose eingesetzt.
# ============================================================

# PostgreSQL (db + webserver)
POSTGRES_PASSWORD=BITTE_AENDERN

# Paperless-ngx (webserver)
PAPERLESS_SECRET_KEY=BITTE_AENDERN_LANGER_ZUFALLSSTRING
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=BITTE_AENDERN

# Lector / Document AI (projektspezifische IDs)
GCP_PROJECT_ID=BITTE_AENDERN
DOCAI_PROCESSOR_ID=BITTE_AENDERN

# paperless-gpt (KI-Tagging)
# Token in Paperless erzeugen: Profil -> API-Token
PAPERLESS_API_TOKEN=BITTE_AENDERN
ANTHROPIC_API_KEY=sk-ant-BITTE_AENDERN

# ============================================================
# Lector standalone (falls Lector ohne die Full-Stack-Compose
# betrieben wird — in der Full-Stack-Compose sind diese Werte
# bereits inline gesetzt).
# ============================================================

# OCR-Engine
OCR_PROVIDER=documentai
GCP_PROJECT_ID=BITTE_AENDERN
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=BITTE_AENDERN
GOOGLE_APPLICATION_CREDENTIALS=/secrets/docai-sa.json

# Ordnerpfade (lokal z.B. ./scan-in usw.)
WATCH_DIR=/scan-in
CONSUME_DIR=/consume
PROCESSED_DIR=/processed
ERROR_DIR=/error
DB_PATH=/data/lector.db

# Lifecycle / Retry / Retention
PROCESSED_RETENTION_DAYS=30
RETRY_DELAY_MINUTES=15
RETRY_MAX=3
CHUNK_SIZE_PAGES=15

# Vorverarbeitung (Orientierung übernimmt Document AI, kein lokales Auto-Rotate)
PREPROCESS_DESKEW=true
PREPROCESS_CONTRAST=true

# Watch-Folder-Vollständigkeitsprüfung
POLL_INTERVAL_SECONDS=2.0
STABILITY_WINDOW_SECONDS=6.0
PARTIAL_SUFFIXES=.tmp,.part,.crdownload

# Throttling
DOCAI_MAX_PAGES_PER_MINUTE=120

TZ=Europe/Berlin
PUID=1000
PGID=1000
HOST=0.0.0.0
PORT=8001

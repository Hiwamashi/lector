# ============================================================
# Stack-Secrets fuer docker-compose.example.yml (Full-Stack)
# Diese Werte werden per ${...} in die Compose eingesetzt.
# ============================================================

# PostgreSQL (db + webserver)
POSTGRES_PASSWORD=BITTE_AENDERN

# Paperless-ngx (webserver)
PAPERLESS_SECRET_KEY=BITTE_AENDERN_LANGER_ZUFALLSSTRING
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=BITTE_AENDERN

# Lector / Document AI (projektspezifische IDs)
GCP_PROJECT_ID=BITTE_AENDERN
DOCAI_PROCESSOR_ID=BITTE_AENDERN

# paperless-gpt (KI-Tagging) + Lector-Paperless-Integration
# Token in Paperless erzeugen: Profil -> API-Token (wird von paperless-gpt
# und — bei aktivem FEATURE_PAPERLESS_SYNC — von Lector verwendet).
PAPERLESS_API_TOKEN=BITTE_AENDERN
ANTHROPIC_API_KEY=sk-ant-BITTE_AENDERN

# SevDesk-Export (nur noetig bei FEATURE_SEVDESK_EXPORT=true)
SEVDESK_API_TOKEN=BITTE_AENDERN

# ============================================================
# Lector standalone (falls Lector ohne die Full-Stack-Compose
# betrieben wird — in der Full-Stack-Compose sind diese Werte
# bereits inline gesetzt).
# ============================================================

# OCR-Engine
OCR_PROVIDER=documentai
GCP_PROJECT_ID=BITTE_AENDERN
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=BITTE_AENDERN
GOOGLE_APPLICATION_CREDENTIALS=/secrets/docai-sa.json

# Ordnerpfade (lokal z.B. ./scan-in usw.)
WATCH_DIR=/scan-in
CONSUME_DIR=/consume
PROCESSED_DIR=/processed
ERROR_DIR=/error
DB_PATH=/data/lector.db

# Lifecycle / Retry / Retention
PROCESSED_RETENTION_DAYS=30
RETRY_DELAY_MINUTES=15
RETRY_MAX=3
CHUNK_SIZE_PAGES=15

# Vorverarbeitung (Orientierung übernimmt Document AI, kein lokales Auto-Rotate)
PREPROCESS_DESKEW=true
PREPROCESS_CONTRAST=true

# Watch-Folder-Vollständigkeitsprüfung
POLL_INTERVAL_SECONDS=2.0
STABILITY_WINDOW_SECONDS=6.0
PARTIAL_SUFFIXES=.tmp,.part,.crdownload

# Throttling
DOCAI_MAX_PAGES_PER_MINUTE=120

TZ=Europe/Berlin
PUID=1000
PGID=1000
HOST=0.0.0.0
PORT=8001

# ============================================================
# Paperless-Integration (entkoppeltes Zusatz-Feature):
# GiroCode-Anzeige + SevDesk-Export. Deaktiviert, solange
# FEATURE_PAPERLESS_SYNC=false.
# ============================================================
FEATURE_PAPERLESS_SYNC=false
# Basis-URL der Paperless-Instanz (ohne abschließenden /api).
PAPERLESS_URL=http://webserver:8000
# API-Token aus Paperless (Profil -> API-Token).
PAPERLESS_TOKEN=BITTE_AENDERN
# Name des Dokumententyps in Paperless, der Rechnungen markiert.
PAPERLESS_INVOICE_DOCTYPE=Rechnung
PAPERLESS_SYNC_INTERVAL_SECONDS=300.0
# Fehlende Custom Fields / Tags beim Start automatisch in Paperless anlegen.
PAPERLESS_AUTO_CREATE_FIELDS=true

# GiroCode: Gläubigername aus dem Paperless-Korrespondenten ableiten, wenn nicht im Beleg.
GIROCODE_CREDITOR_FROM_CORRESPONDENT=true

# SevDesk-Export (leichtgewichtiger Beleg-Upload)
FEATURE_SEVDESK_EXPORT=false
SEVDESK_API_TOKEN=BITTE_AENDERN
SEVDESK_BASE_URL=https://my.sevdesk.de/api/v1
# Paperless-Tag, der den Export auslöst.
SEVDESK_TAG=sevdesk
# true = automatischer Export beim Sync, false = nur vormerken (manuell im UI bestätigen).
SEVDESK_AUTO_EXPORT=false

# Namen der Paperless-Custom-Fields / -Tags für den Rückschrieb ans Dokument.
CF_GIRO_IBAN=Zahlung IBAN
CF_GIRO_AMOUNT=Zahlbetrag
CF_SEVDESK_ID=SevDesk-Beleg
CF_EXPORTED_AT=SevDesk-Export am
CF_PAID=Überwiesen
TAG_SEVDESK_DONE=sevdesk-exportiert
TAG_PAID=überwiesen

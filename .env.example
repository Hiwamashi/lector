# OCR-Engine
OCR_PROVIDER=documentai
GCP_PROJECT_ID=BITTE_AENDERN
DOCAI_LOCATION=eu
DOCAI_PROCESSOR_ID=BITTE_AENDERN
GOOGLE_APPLICATION_CREDENTIALS=/secrets/docai-sa.json

# Ordnerpfade (lokal z.B. ./scan-in usw.)
WATCH_DIR=/scan-in
CONSUME_DIR=/consume
PROCESSED_DIR=/processed
ERROR_DIR=/error
DB_PATH=/data/lector.db

# Lifecycle / Retry / Retention
PROCESSED_RETENTION_DAYS=30
RETRY_DELAY_MINUTES=15
RETRY_MAX=3
CHUNK_SIZE_PAGES=15

# Vorverarbeitung
PREPROCESS_DESKEW=true
PREPROCESS_AUTOROTATE=true
PREPROCESS_CONTRAST=true

# Watch-Folder-Vollständigkeitsprüfung
POLL_INTERVAL_SECONDS=2.0
STABILITY_WINDOW_SECONDS=6.0
PARTIAL_SUFFIXES=.tmp,.part,.crdownload

# Throttling
DOCAI_MAX_PAGES_PER_MINUTE=120

TZ=Europe/Berlin
PUID=1000
PGID=1000
HOST=0.0.0.0
PORT=8001
